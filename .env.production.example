# Environment Variables for Production
# Copy this file to .env.production and fill in your actual values

# Security (REQUIRED - CHANGE THESE!)
STOREDESK_AI_HMAC_SECRET=your-super-secure-hmac-secret-32-chars-minimum
STOREDESK_AI_SERVICE_KEY=hashed-service-key-here
HMAC_SECRET=must-match-backend-hmac-secret
SERVICE_ACCOUNT_KEY=must-match-backend-service-key

# Supported LLM provider keys (at least one required)
GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key

# Optional: Mock Server (testing only)
MOCK_SERVICE_KEY=your-mock-service-key

# Database and Services
REDIS_URL=redis://redis:6379

# Application Settings
NODE_ENV=production
DEBUG_ENDPOINTS_ENABLED=false
ENVIRONMENT=production
WHISPER_MODEL_SIZE=base

# Rate Limiting (Node gateway)
STOREDESK_AI_RATE_LIMIT_PER_USER=30
STOREDESK_AI_RATE_LIMIT_WINDOW_SECONDS=60

# Rate Limiting (AI service defense-in-depth)
RATE_LIMIT_PER_USER=30
RATE_LIMIT_WINDOW_SECONDS=60

# Allowed Mutations
STOREDESK_AI_ALLOWED_MUTATIONS=updateBulkStockMonitoringCommand,updateBulkPriceMonitoringCommand

# AI Service Settings
SESSION_TTL_SECONDS=7200
MAX_HISTORY_TURNS=20
PROVIDER_BACKOFF_SECONDS=300
REQUEST_MAX_ITERATIONS=5

# Service URLs
STOREDESK_AI_URL=http://storedesk-ai:8000
NODEJS_GRAPHQL_URL=http://nodejs:4010/graphql
