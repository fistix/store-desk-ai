# Server Configuration
PORT=8000
ENVIRONMENT=development
DEBUG_ENDPOINTS_ENABLED=true

# Security
HMAC_SECRET=your-hmac-secret-here-must-match-backend
NODEJS_GRAPHQL_URL=http://localhost:4010/graphql
SERVICE_ACCOUNT_KEY=your-service-account-key-here

# Redis
REDIS_URL=redis://localhost:6379

# Supported LLM providers (configure at least one)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Speech-to-Text
WHISPER_MODEL_SIZE=base

# Limits and Configuration
SESSION_TTL_SECONDS=7200
MAX_HISTORY_TURNS=20
PROVIDER_BACKOFF_SECONDS=300
REQUEST_MAX_ITERATIONS=5
